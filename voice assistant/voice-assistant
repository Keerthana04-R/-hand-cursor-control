import os
import json
import queue
import threading
import sounddevice as sd
import numpy as np
import pyttsx3
from vosk import Model, KaldiRecognizer
import webbrowser
import datetime
import sys

# ================= CONFIG =================
MODEL_PATH       = "vosk-model-small-en-us-0.4"
SAMPLE_RATE      = 16000
CHANNELS         = 1
BLOCKSIZE        = 8000
VOLUME_GAIN      = 40.0     # mic boost (increase if voice not detected)
SILENCE_THRESHOLD = 30      # lowered so voice gets through
DEVICE_INDEX     = None     # None = auto-detect best mic
DEBUG_VOLUME     = True     # set False to hide volume meter
# ==========================================


# ─────────────────────────────────────────
#  AUTO-DETECT MIC
# ─────────────────────────────────────────
def find_best_mic():
    devices = sd.query_devices()
    print("\n📋 Available audio devices:")
    for i, d in enumerate(devices):
        tag = "  "
        if d["max_input_channels"] > 0:
            tag = "🎤"
        print(f"  [{i}] {tag} {d['name']}  (in={d['max_input_channels']})")

    # prefer default input device
    default = sd.default.device[0]
    if default is not None and devices[default]["max_input_channels"] > 0:
        print(f"\n✅ Using default input device [{default}]: {devices[default]['name']}\n")
        return default

    # fallback: first device with input channels
    for i, d in enumerate(devices):
        if d["max_input_channels"] > 0:
            print(f"\n✅ Using first available input [{i}]: {d['name']}\n")
            return i

    print("❌ No input devices found.")
    sys.exit(1)


# ─────────────────────────────────────────
#  TTS ENGINE
# ─────────────────────────────────────────
engine = pyttsx3.init()
engine.setProperty("rate", 160)
tts_lock = threading.Lock()

def speak(text):
    print(f"\n🤖 Assistant: {text}")
    with tts_lock:
        engine.say(text)
        engine.runAndWait()


# ─────────────────────────────────────────
#  VOSK MODEL
# ─────────────────────────────────────────
if not os.path.exists(MODEL_PATH):
    print(f"❌ Vosk model not found at: {MODEL_PATH}")
    print("   Download from: https://alphacephei.com/vosk/models")
    print("   Recommended: vosk-model-small-en-us-0.15  (40 MB, fast)")
    sys.exit(1)

print("⏳ Loading Vosk model...")
model = Model(MODEL_PATH)
recognizer = KaldiRecognizer(model, SAMPLE_RATE)
print("✅ Model loaded.\n")

audio_queue = queue.Queue()


# ─────────────────────────────────────────
#  AUDIO CALLBACK
# ─────────────────────────────────────────
def audio_callback(indata, frames, time_info, status):
    if status:
        print(f"⚠️  Audio status: {status}")

    audio = np.frombuffer(indata, dtype=np.int16).astype(np.float32)
    audio = audio * VOLUME_GAIN
    audio = np.clip(audio, -32768, 32767).astype(np.int16)

    volume = np.abs(audio).mean()

    if DEBUG_VOLUME:
        bar = int(volume / 50)
        bar = min(bar, 30)
        print(f"\r  📊 Volume: {volume:6.1f}  {'█' * bar}{'░' * (30 - bar)} ", end="", flush=True)

    if volume > SILENCE_THRESHOLD:
        audio_queue.put(audio.tobytes())


# ─────────────────────────────────────────
#  LISTEN
# ─────────────────────────────────────────
def listen_command():
    recognizer.Reset()
    # drain stale audio
    while not audio_queue.empty():
        audio_queue.get_nowait()

    print("\n🎤 Listening... (speak now)")

    while True:
        try:
            data = audio_queue.get(timeout=15)
        except queue.Empty:
            print("\n⏱️  Timeout — no speech detected.")
            return ""

        if recognizer.AcceptWaveform(data):
            result = json.loads(recognizer.Result())
            text = result.get("text", "").strip()
            if text:
                print(f"\n👤 You said: \"{text}\"")
                return text.lower()
        else:
            partial = json.loads(recognizer.PartialResult()).get("partial", "")
            if partial:
                print(f"\r  💬 Hearing: {partial}...   ", end="", flush=True)


# ─────────────────────────────────────────
#  COMMAND HANDLERS
# ─────────────────────────────────────────
def cmd_open_google():
    speak("Opening Google")
    webbrowser.open("https://www.google.com")

def cmd_open_youtube():
    speak("Opening YouTube")
    webbrowser.open("https://www.youtube.com")

def cmd_open_github():
    speak("Opening GitHub")
    webbrowser.open("https://www.github.com")

def cmd_time():
    now = datetime.datetime.now().strftime("%I:%M %p")
    speak(f"The time is {now}")

def cmd_date():
    today = datetime.datetime.now().strftime("%A, %d %B %Y")
    speak(f"Today is {today}")

def cmd_day():
    day = datetime.datetime.now().strftime("%A")
    speak(f"Today is {day}")

def cmd_weather():
    speak("Opening weather forecast")
    webbrowser.open("https://www.weather.com")

def cmd_wikipedia(command):
    query = command.replace("search", "").replace("wikipedia", "").replace("wiki", "").strip()
    if query:
        speak(f"Searching Wikipedia for {query}")
        webbrowser.open(f"https://en.wikipedia.org/wiki/{query.replace(' ', '_')}")
    else:
        speak("What should I search on Wikipedia?")

def cmd_google_search(command):
    query = command.replace("search for", "").replace("search", "").replace("google", "").strip()
    if query:
        speak(f"Searching Google for {query}")
        webbrowser.open(f"https://www.google.com/search?q={query.replace(' ', '+')}")
    else:
        speak("What should I search for?")

def cmd_battery():
    try:
        import psutil
        battery = psutil.sensors_battery()
        if battery:
            status = "charging" if battery.power_plugged else "not charging"
            speak(f"Battery is at {int(battery.percent)} percent and {status}")
        else:
            speak("Could not read battery information")
    except ImportError:
        speak("psutil is not installed. Run: pip install psutil")

def cmd_calculator():
    import subprocess
    try:
        subprocess.Popen("calc")
        speak("Opening calculator")
    except Exception:
        speak("Could not open calculator")

def cmd_notepad():
    import subprocess
    try:
        subprocess.Popen("notepad")
        speak("Opening Notepad")
    except Exception:
        speak("Could not open Notepad")

def cmd_joke():
    try:
        import pyjokes
        joke = pyjokes.get_joke()
        speak(joke)
    except ImportError:
        jokes = [
            "Why do programmers prefer dark mode? Because light attracts bugs!",
            "Why did the programmer quit? Because he didn't get arrays.",
            "A SQL query walks into a bar, walks up to two tables and asks: Can I join you?",
        ]
        import random
        speak(random.choice(jokes))

def cmd_help():
    speak(
        "Here are things I can do. "
        "Open Google, YouTube, or GitHub. "
        "Tell you the time, date, or day. "
        "Search Google or Wikipedia. "
        "Check battery. "
        "Open calculator or Notepad. "
        "Tell a joke. "
        "Say stop or exit to quit."
    )

def log_command(command):
    with open("command_log.txt", "a", encoding="utf-8") as f:
        ts = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        f.write(f"[{ts}] {command}\n")


# ─────────────────────────────────────────
#  COMMAND ROUTER
# ─────────────────────────────────────────
def handle_command(command):
    if not command:
        return True  # continue loop

    log_command(command)

    if "open google" in command:
        cmd_open_google()
    elif "open youtube" in command:
        cmd_open_youtube()
    elif "open github" in command:
        cmd_open_github()
    elif "open calculator" in command or "calculator" in command:
        cmd_calculator()
    elif "open notepad" in command or "notepad" in command:
        cmd_notepad()
    elif "time" in command:
        cmd_time()
    elif "date" in command:
        cmd_date()
    elif "day" in command:
        cmd_day()
    elif "weather" in command:
        cmd_weather()
    elif "battery" in command:
        cmd_battery()
    elif "joke" in command:
        cmd_joke()
    elif "help" in command:
        cmd_help()
    elif "wikipedia" in command or "wiki" in command:
        cmd_wikipedia(command)
    elif "search for" in command or "search" in command:
        cmd_google_search(command)
    elif "exit" in command or "stop" in command or "quit" in command or "bye" in command:
        speak("Goodbye! Have a great day.")
        return False  # signal to stop

    else:
        speak("Sorry, I did not understand that. Say help to hear what I can do.")

    return True  # continue loop


# ─────────────────────────────────────────
#  MAIN
# ─────────────────────────────────────────
def run_assistant():
    hour = datetime.datetime.now().hour
    if hour < 12:
        greeting = "Good morning"
    elif hour < 18:
        greeting = "Good afternoon"
    else:
        greeting = "Good evening"

    speak(f"{greeting}! I am your voice assistant.")
    speak("Say help to hear available commands.")

    mic_index = DEVICE_INDEX if DEVICE_INDEX is not None else find_best_mic()

    print(f"🎙️  Mic device index : {mic_index}")
    print(f"🎧  Sample rate      : {SAMPLE_RATE}")
    print(f"🔊  Volume gain      : {VOLUME_GAIN}")
    print(f"🔇  Silence threshold: {SILENCE_THRESHOLD}")
    print(f"📄  Logging to       : command_log.txt\n")
    print("─" * 50)

    try:
        with sd.RawInputStream(
            samplerate=SAMPLE_RATE,
            blocksize=BLOCKSIZE,
            device=mic_index,
            dtype="int16",
            channels=CHANNELS,
            callback=audio_callback,
        ):
            running = True
            while running:
                command = listen_command()
                running = handle_command(command)

    except sd.PortAudioError as e:
        print(f"\n❌ Microphone error: {e}")
        print("   Try changing DEVICE_INDEX in config.")
        sys.exit(1)
    except KeyboardInterrupt:
        print("\n\n👋 Interrupted by user. Goodbye!")


# ─────────────────────────────────────────
#  ENTRY POINT
# ─────────────────────────────────────────
if __name__ == "__main__":
    run_assistant()